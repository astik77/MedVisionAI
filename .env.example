# ============================================================
# MedVisionAI — Environment Variables Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
POSTGRES_USER=medvision
POSTGRES_PASSWORD=supersecretpassword
POSTGRES_DB=medvisiondb
DATABASE_URL=postgresql://medvision:supersecretpassword@db:5432/medvisiondb

# --- JWT ---
SECRET_KEY=change_me_to_a_long_random_string_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- App ---
ENVIRONMENT=development

# --- CORS (comma-separated list of allowed origins) ---
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Storage ---
UPLOAD_DIR=/app/uploads

# --- Frontend ---
VITE_API_URL=http://localhost:8000
